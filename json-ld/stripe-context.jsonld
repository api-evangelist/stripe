          "@id": "schema:dateCreated",
          "@type": "xsd:integer"
        },
        "livemode": {
          "@id": "stripe:livemode",
          "@type": "xsd:boolean"
        },
        "metadata": {
          "@id": "stripe:metadata",
          "@type": "@json"
        }
      }
    },
