        },
        "description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "active": {
          "@id": "stripe:active",
          "@type": "xsd:boolean"
        },
        "images": {
          "@id": "schema:image",
          "@container": "@list"
        },
        "url": {
          "@id": "schema:url",
          "@type": "@id"
        },
        "created": {
          "@id": "schema:dateCreated",
          "@type": "xsd:integer"
        },
        "updated": {
          "@id": "schema:dateModified",
          "@type": "xsd:integer"
        },
        "type": {
          "@id": "stripe:productType",
          "@type": "xsd:string"
        },
        "livemode": {
          "@id": "stripe:livemode",
          "@type": "xsd:boolean"
        },
        "metadata": {
          "@id": "stripe:metadata",
          "@type": "@json"
        }
      }
    },
    "Price": {
      "@id": "stripe:Price",
