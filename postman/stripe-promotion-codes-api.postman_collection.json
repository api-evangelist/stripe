                  "mode": "urlencoded",
                  "urlencoded": [
                    {
                      "description": "(Required) The coupon for this promotion code.",
                      "key": "coupon",
                      "value": "<string>"
                    },
                    {
                      "description": "The customer-facing code. If not provided, Stripe will generate one.",
                      "key": "code",
                      "value": "<string>"
                    },
                    {
                      "description": "Whether the promotion code is currently active.",
                      "key": "active",
                      "value": "<boolean>"
                    },
                    {
                      "description": "The customer that this promotion code can be used by.",
                      "key": "customer",
                      "value": "<string>"
                    },
                    {
                      "description": "The timestamp at which this promotion code will expire.",
                      "key": "expires_at",
                      "value": "<integer>"
