{
  "opencollection": "1.0.0",
  "info": {
    "name": "Stripe Forwarding API",
    "version": "2024-06-20"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Forwarding",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Stripe List Forwarding Requests",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/forwarding/requests",
            "params": [
              {
                "name": "ending_before",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "starting_after",
                "value": "",
                "type": "query"
              },
              {
                "name": "expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Lists all ForwardingRequest objects.</p>"
        },
        {
          "info": {
            "name": "Stripe Create Forwarding Request",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/forwarding/requests",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "payment_method",
                  "value": ""
                },
                {
                  "name": "url",
                  "value": ""
                },
                {
                  "name": "replacements",
                  "value": ""
                },
                {
                  "name": "request",
                  "value": ""
                },
                {
                  "name": "metadata",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>Creates a ForwardingRequest object.</p>"
        },
        {
          "info": {
            "name": "Stripe Retrieve Forwarding Request",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/forwarding/requests/:id",
            "params": [
              {
                "name": "id",
                "value": "",
                "type": "path"
              },
              {
                "name": "expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Retrieves a ForwardingRequest object.</p>"
        }
      ]
    }
  ],
  "bundled": true
}