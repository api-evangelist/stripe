{
  "opencollection": "1.0.0",
  "info": {
    "name": "Stripe Refunds API",
    "version": "2024-06-20"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Refunds",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Stripe List Refunds",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/refunds",
            "params": [
              {
                "name": "charge",
                "value": "",
                "type": "query",
                "description": "Only return refunds for the charge specified by this charge ID."
              },
              {
                "name": "payment_intent",
                "value": "",
                "type": "query",
                "description": "Only return refunds for the PaymentIntent specified by this ID."
              },
              {
                "name": "ending_before",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "starting_after",
                "value": "",
                "type": "query"
              },
              {
                "name": "expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Returns a list of all refunds you created.</p>"
        },
        {
          "info": {
            "name": "Stripe Create Refund",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/refunds",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "charge",
                  "value": ""
                },
                {
                  "name": "payment_intent",
                  "value": ""
                },
                {
                  "name": "amount",
                  "value": ""
                },
                {
                  "name": "reason",
                  "value": ""
                },
                {
                  "name": "metadata",
                  "value": ""
                },
                {
                  "name": "reverse_transfer",
                  "value": ""
                },
                {
                  "name": "refund_application_fee",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>When you create a new refund, you must specify a Charge or PaymentIntent object on which to create it.</p>"
        },
        {
          "info": {
            "name": "Stripe Retrieve Refund",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/refunds/:refund",
            "params": [
              {
                "name": "refund",
                "value": "",
                "type": "path"
              },
              {
                "name": "expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Retrieves the details of an existing refund.</p>"
        },
        {
          "info": {
            "name": "Stripe Update Refund",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/refunds/:refund",
            "params": [
              {
                "name": "refund",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "metadata",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>Updates the refund that you specify by setting the values of the parameters that you pass.</p>"
        },
        {
          "info": {
            "name": "Stripe Cancel Refund",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/refunds/:refund/cancel",
            "params": [
              {
                "name": "refund",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "<p>Cancels a refund with a status of requires_action.</p>"
        }
      ]
    }
  ],
  "bundled": true
}