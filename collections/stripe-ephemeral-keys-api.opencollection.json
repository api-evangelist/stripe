{
  "opencollection": "1.0.0",
  "info": {
    "name": "Stripe Ephemeral Keys API",
    "version": "2023-10-16"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Keys",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Stripe Post   Ephemeral Keys",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/ephemeral_keys",
            "body": {
              "type": "form-urlencoded",
              "data": []
            }
          },
          "docs": "<p>Creates a short-lived API key for a given resource.</p>"
        }
      ]
    },
    {
      "info": {
        "name": "Delete",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Stripe Delete   Ephemeral Keys Key",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://api.stripe.com/v1/ephemeral_keys/:key",
            "params": [
              {
                "name": "key",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": []
            }
          },
          "docs": "<p>Invalidates a short-lived API key for a given resource.</p>"
        }
      ]
    }
  ],
  "bundled": true
}