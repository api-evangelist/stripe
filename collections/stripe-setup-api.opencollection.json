{
  "opencollection": "1.0.0",
  "info": {
    "name": "Stripe Setup API",
    "version": "2024-06-20"
  },
  "request": {
    "auth": {
      "type": "basic",
      "username": "{{username}}",
      "password": "{{password}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Setup Intents",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Setup Intents",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/setup_intents",
            "params": [
              {
                "name": "customer",
                "value": "",
                "type": "query",
                "description": "Only return SetupIntents for the customer specified by this customer ID."
              },
              {
                "name": "payment_method",
                "value": "",
                "type": "query",
                "description": "Only return SetupIntents that associate with the specified payment method."
              },
              {
                "name": "ending_before",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "starting_after",
                "value": "",
                "type": "query"
              },
              {
                "name": "expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Returns a list of SetupIntents.</p>"
        },
        {
          "info": {
            "name": "Create Setup Intent",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/setup_intents",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "confirm",
                  "value": ""
                },
                {
                  "name": "customer",
                  "value": ""
                },
                {
                  "name": "description",
                  "value": ""
                },
                {
                  "name": "metadata",
                  "value": ""
                },
                {
                  "name": "payment_method",
                  "value": ""
                },
                {
                  "name": "payment_method_types",
                  "value": ""
                },
                {
                  "name": "return_url",
                  "value": ""
                },
                {
                  "name": "usage",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>Creates a SetupIntent object. After you create the SetupIntent, attach a payment method and confirm it to collect any required permissions to charge the payment method later.</p>"
        },
        {
          "info": {
            "name": "Retrieve Setup Intent",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/setup_intents/:intent",
            "params": [
              {
                "name": "intent",
                "value": "",
                "type": "path"
              },
              {
                "name": "client_secret",
                "value": "",
                "type": "query",
                "description": "The client secret of the SetupIntent."
              },
              {
                "name": "expand",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Retrieves the details of a SetupIntent that has previously been created.</p>"
        },
        {
          "info": {
            "name": "Update Setup Intent",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/setup_intents/:intent",
            "params": [
              {
                "name": "intent",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "customer",
                  "value": ""
                },
                {
                  "name": "description",
                  "value": ""
                },
                {
                  "name": "metadata",
                  "value": ""
                },
                {
                  "name": "payment_method",
                  "value": ""
                },
                {
                  "name": "payment_method_types",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>Updates a SetupIntent object.</p>"
        },
        {
          "info": {
            "name": "Confirm Setup Intent",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/setup_intents/:intent/confirm",
            "params": [
              {
                "name": "intent",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "payment_method",
                  "value": ""
                },
                {
                  "name": "return_url",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>Confirm that your customer intends to set up the current or provided payment method.</p>"
        },
        {
          "info": {
            "name": "Cancel Setup Intent",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.stripe.com/v1/setup_intents/:intent/cancel",
            "params": [
              {
                "name": "intent",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "cancellation_reason",
                  "value": ""
                }
              ]
            }
          },
          "docs": "<p>You can cancel a SetupIntent object when it's in one of these statuses: requires_payment_method, requires_confirmation, or requires_action.</p>"
        },
        {
          "info": {
            "name": "List Setup Attempts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.stripe.com/v1/setup_attempts",
            "params": [
              {
                "name": "setup_intent",
                "value": "",
                "type": "query"
              },
              {
                "name": "ending_before",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "starting_after",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "<p>Returns a list of SetupAttempts that associate with a provided SetupIntent.</p>"
        }
      ]
    }
  ],
  "bundled": true
}